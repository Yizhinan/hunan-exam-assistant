# 湖南公考助手 — 环境变量配置
# 复制为 .env 并填入实际值

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# JWT
JWT_SECRET=change-me-to-a-random-string

# Database (docker-compose 默认值)
DATABASE_URL=postgresql+asyncpg://hea_user:hea_password@localhost:5432/hunan_exam

# Redis
REDIS_URL=redis://localhost:6379/0

# Pipeline (crawler → backend) auth token — any valid JWT from /api/auth/login
PIPELINE_API_TOKEN=

# HuggingFace 国内镜像（下载嵌入模型用，约 1.3GB，首次启动需等待下载）
HF_ENDPOINT=
